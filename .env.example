# GitHub Personal Access Token
# Required: contents:write permission on DATASET_REPO
GITHUB_TOKEN=your_pat_here

# GitHub organization or user that owns the dataset repository
# Production: agent-manifest
# Local/dev fallback: hernancapucci
GITHUB_OWNER=agent-manifest

# Name of the dataset repository
# Value is the same before and after org migration
DATASET_REPO=agent-manifest-dataset
